# =====================================================================
# Configuración del Entorno - Tasf.B2B Backend
# Despliegue LOCAL en VM Ubuntu (sin AWS, sin cloud)
# ⚠ NO subir este archivo a Git (.gitignore debe incluirlo)
# =====================================================================

# ── Servidor ──────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Base de datos MySQL 8.4 (contenedor local) ────────────────────────────────
# En docker-compose el host es el nombre del servicio "db"
# Para desarrollo local fuera de Docker: usar "localhost"
DB_HOST=localhost
DB_PORT=3306
DB_NAME=baseEquipo7G
DB_USERNAME=grupo7g
DB_PASSWORD=Root.Tasf-2026_PUCP!

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=cambia-esta-clave-por-una-cadena-aleatoria-de-256-bits-minimo-produccion-2025
JWT_EXPIRATION=86400000

# ── CORS ──────────────────────────────────────────────────────────────
# En producción: solo el dominio o IP de tu Nginx
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:4200

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=WARN
